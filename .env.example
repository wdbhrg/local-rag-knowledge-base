# Copy to .env and fill in, or set in system environment.
# Never commit .env — it is listed in .gitignore.
#
# 网页侧栏可选「云端」或「本机 OpenAI 兼容」（Ollama / LM Studio / llama.cpp 等）。命令行 ask_kb：未设置 OPENAI_BASE_URL 时默认本机接口；
# 若在纯 CLI 下更喜欢云端默认，可设置： KB_DEFAULT_API_BACKEND=cloud
# 网页默认侧栏模式：KB_UI_MODEL_BACKEND=cloud 或 local（旧值 ollama 等价于 local）
# 侧栏额外探测地址（逗号分隔、须含 /v1）：KB_LOCAL_PROBE_BASES=http://127.0.0.1:9999/v1
# CLI/API 将环回地址视为「可无密钥」的端口（可追加）：KB_LOCAL_OPENAI_PORTS=9999
#
# start.bat 不读取本文件；若需改 Miniconda 路径请在系统环境变量或 cmd 里 set MINICONDA_ROOT=...
# 默认已为 E:\Project Tools\Miniconda3，项目内环境目录为 .conda_env\

OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
OPENAI_API_KEY=
# Or: ARK_API_KEY=

OPENAI_MODEL=

# KB_DEFAULT_API_BACKEND=cloud
# KB_UI_MODEL_BACKEND=local

# 本机 OpenAI 兼容：可不设 Key，ask_kb 会用占位符；DeepSeek R1 关闭长思考链（可选，仅 Ollama）
# KB_LOCAL_API_KEY_PLACEHOLDER=ollama
# KB_OLLAMA_THINK=0
# KB_DEEPSEEK_R1_DOC_MODE=1

# 本地模型提示加强（0 关闭）
# KB_RAG_TUNED=1

# Optional: absolute path to your documents folder (overrides kb_library_root.txt from the UI)
# KB_LIBRARY_ROOT=

KB_CONTEXT_CHARS=2400
KB_MAX_TOKENS=4096
KB_TEMPERATURE=0.35

# Performance (optional)
# KB_HTTP_POOL_MAXSIZE=32
# KB_CROSS_ENCODER_BATCH=32
# KB_SQLITE_CACHE_KIB=32768
# KB_SQLITE_MMAP_MB=0

# Pipeline: query rewrite / Self-RAG / routing (1=on, 0=off)
# KB_QUERY_REWRITE=1
# KB_SELF_RAG=1
# KB_ROUTING=0
# KB_ROUTER_USE_LLM=0

# Indexing: sentence (default) or semantic — needs pip install -r requirements-optional.txt
# KB_CHUNK_STRATEGY=sentence
# KB_SEMANTIC_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# KB_SEMANTIC_DISTANCE_PERCENTILE=78
# KB_SEMANTIC_MIN_CHUNK=150

# Vector column in chunk_vectors (hybrid retrieval). Rebuild index after enabling if table was empty.
# KB_VECTOR_INDEX=1
# KB_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# RAGAS eval: embedding model for answer_relevancy (OpenAI-compatible /v1/embeddings)
# KB_EVAL_EMBEDDING_MODEL=text-embedding-3-small

# Hybrid: FTS BM25 + dense similarity, RRF merge; then Cross-Encoder rerank top KB_RERANK_POOL (default 20).
# KB_HYBRID_SEARCH=1
# KB_CROSS_RERANK=1
# KB_CROSS_ENCODER_MODEL=BAAI/bge-reranker-base
# KB_RRF_K=60
# KB_HYBRID_FTS_POOL=100
# KB_HYBRID_VECTOR_POOL=100
# KB_RERANK_POOL=20

# Optional RAG retrieval tuning (ask_kb.retrieve)
# KB_RETRIEVE_OVERSAMPLE=4
# KB_RERANK_COVER_WEIGHT=1.25
# KB_RERANK_TITLE_WEIGHT=0.35
# KB_MAX_CHUNKS_PER_DOC=3
# KB_FTS_MAX_TERMS=14

# GraphRAG（LightRAG 思路轻量版）：全量建索引末尾写 chunk_graph_edges；问答时按槽位并入邻居块
# KB_BUILD_GRAPH=1
# KB_GRAPH_RAG=0
# KB_GRAPH_SLOTS=2
# KB_GRAPH_EXPAND_PER_SEED=2

# 语义缓存（SQLite，需 sentence-transformers）：相似问句直接返回答案，跳过检索与 LLM
# KB_SEMANTIC_CACHE=0
# KB_SEMANTIC_CACHE_THRESHOLD=0.95
# KB_SEMANTIC_CACHE_WRITE=1
# KB_SEMANTIC_CACHE_MAX=400
# 向量已 L2 归一化时跳过重复 normalize（语义缓存与 chunk 检索共用）
# KB_VECTOR_UNIT_EPS=0.001

# 混合检索：BM25 强命中时减半向量候选池
# KB_HYBRID_STRONG_MATCH_DEGRADE=1

# 索引：仅前 N 字符参与 FTS/向量（text_raw 仍存全文）；0=全文
# KB_SEARCH_SPAN_CHARS=0

# 可选 FastAPI：api_server.py —— KB_SQLITE_PATH
# KB_SQLITE_PATH=knowledge_base.sqlite
